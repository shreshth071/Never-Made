-- 1. SECURE THE PROFILES TABLE
-- Allow everyone to see and edit only THEIR OWN profile
ALTER TABLE profiles ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Users can manage own profile" 
ON profiles FOR ALL 
TO authenticated 
USING (auth.uid() = id)
WITH CHECK (auth.uid() = id);

-- 2. SECURE THE ORDERS TABLE
-- Allow users to see only their history, but let Admin see EVERYTHING
ALTER TABLE orders ENABLE ROW LEVEL SECURITY;

-- Rule for users (Personal Privacy)
CREATE POLICY "Users can view personal orders" 
ON orders FOR SELECT 
TO authenticated 
USING (auth.uid() = user_id);

-- Rule for Admin (Global Visibility)
CREATE POLICY "Admin has master view" 
ON orders FOR ALL 
TO authenticated 
USING (auth.jwt() ->> 'email' = 'shadowfx1000@gmail.com');

-- 3. SECURE ORDER ITEMS (Relational Link)
ALTER TABLE order_items ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Users can view personal items" 
ON order_items FOR SELECT 
TO authenticated 
USING (
  EXISTS (
    SELECT 1 FROM orders 
    WHERE orders.id = order_items.order_id 
    AND (orders.user_id = auth.uid() OR auth.jwt() ->> 'email' = 'shadowfx1000@gmail.com')
  )
);
